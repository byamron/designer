# Rust
/target/
**/*.rs.bk

# Node / Vite
node_modules/
dist/
.vite/

# App local data
~/.designer/
*.db
*.db-wal
*.db-shm

# Sandbox event store written by `just dev` — keeps in-progress
# branches from corrupting the daily-driver's ~/.designer/.
.dev-data/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Tauri
apps/desktop/src-tauri/gen/

# Claude Code runtime scratch
.claude/scheduled_tasks.lock

# Supply-chain CI scratch (cargo cyclonedx / cargo audit / npm audit emit
# these next to each Cargo.toml or at repo root during local verification;
# CI runners produce them in their own workspace and upload them as artifacts).
sbom.json
**/sbom.json
audit.json
npm-audit.json

# Visual regression diff/actual outputs — only baselines (*.png without
# .diff/.actual suffixes) are committed; everything else is ephemeral.
packages/app/src/test/visual/__screenshots__/*.diff.png
packages/app/src/test/visual/__screenshots__/*.actual.png
