{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Designer",
  "version": "0.1.0",
  "identifier": "com.benyamron.designer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../../../packages/app/dist"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "category": "DeveloperTool",
    "shortDescription": "Local-first AI product cockpit",
    "longDescription": "Designer orchestrates AI agents, design, and engineering from one local cockpit."
  }
}
